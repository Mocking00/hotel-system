# Activar rewrite engine
RewriteEngine On

# Variables de entorno para InfinityFree (aplican a todo el proyecto)
SetEnv DB_HOST "sql111.infinityfree.com"
SetEnv DB_PORT "3306"
SetEnv DB_NAME "if0_41615483_hotel_gestion"
SetEnv DB_USER "if0_41615483"
SetEnv DB_PASS "ZA6FhjuOWP"
SetEnv APP_ENV "production"

# Redirigir a index.php si no es un archivo o directorio
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]

# Prevenir acceso directo a archivos PHP de configuración
<FilesMatch "^(config|\.env)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Configuración de errores
# En hosting compartido puede no estar permitido usar php_flag/php_value